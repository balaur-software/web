{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 110 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "noNonNullAssertion": "off" }
    }
  },
  "files": {
    "includes": [
      "packages/**/*.{ts,tsx,json}",
      "apps/**/*.{ts,tsx,json}",
      "*.json",
      "!**/node_modules",
      "!**/dist",
      "!**/storybook-static",
      "!**/*.d.ts"
    ]
  }
}
