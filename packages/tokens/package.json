    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./fonts/*": "./fonts/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {}
}
