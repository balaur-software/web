# EditorConfig — consistent formatting across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs (gofmt); width 4 is the conventional display.
[*.go]
indent_style = tab
indent_size = 4

# Makefiles require real tabs for recipe lines.
[Makefile]
indent_style = tab

# Don't strip trailing spaces in Markdown (they encode hard line breaks).
[*.md]
trim_trailing_whitespace = false

[*.{json,jsonc,yml,yaml,toml}]
indent_style = space
indent_size = 2
